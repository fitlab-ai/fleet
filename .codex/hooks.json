{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "^Bash$",
        "hooks": [
          {
            "type": "command",
            "command": "sh \"$(git rev-parse --show-toplevel)/.agents/hooks/check-version-format.sh\"",
            "timeout": 5,
            "statusMessage": "Checking template version before git commit"
          }
        ]
      }
    ]
  }
}
