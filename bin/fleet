#!/usr/bin/env python3
"""fleet — CLI proxy node manager backed by sing-box.

Two modes:
  proxy   HTTP/SOCKS on 127.0.0.1:7890   (no root, also sets macOS system proxy)
  tun     System-wide TUN + fake-IP DNS  (needs sudo, transparent for Docker)

Usage:
  fleet refresh                   Parse Clash config
  fleet list                      List all nodes
  fleet ping [node]               Test node latency (TCP)

  fleet proxy start <node>        Start proxy mode
  fleet proxy stop                Stop proxy mode
  fleet proxy switch <node>       Switch node (proxy mode)

  fleet tun start <node>          Start TUN mode (sudo)
  fleet tun stop                  Stop TUN mode (sudo)
  fleet tun switch <node>         Switch node (TUN mode, sudo)

  fleet start <node>              Smart start (proxy mode default)
  fleet stop                      Stop whatever is running
  fleet status                    Show all modes
  fleet switch <node>             Switch in active mode
"""

import json
import getpass
import hashlib
import os
import re
import shutil
import socket
import subprocess
import sys
import tempfile
import time
import urllib.error
import urllib.parse
import urllib.request
import uuid
from datetime import datetime, timezone
from pathlib import Path
from typing import Any, Dict, List, Optional

# ── Paths ─────────────────────────────────────────────────────────────────────

def _env_int(name: str, default: int) -> int:
    value = os.environ.get(name)
    if not value:
        return default
    try:
        return int(value)
    except ValueError:
        print(f"Warning: ignoring invalid {name}={value!r}")
        return default


CONFIG_DIR = Path.home() / ".config/fleet"
NODES_FILE = CONFIG_DIR / "nodes.json"
STATE_FILE = CONFIG_DIR / "state.json"
SING_BOX_CONFIG = CONFIG_DIR / "sing-box.json"
SING_BOX_LOG = CONFIG_DIR / "sing-box.log"
SING_BOX_BIN = "/opt/homebrew/bin/sing-box"
CLASH_CONFIG = Path.home() / "Library/Application Support/com.follow.clash/config.yaml"
SUBSCRIPTION_USER_AGENT = "clash.meta"
SUBSCRIPTION_TIMEOUT_SECONDS = _env_int("FLEET_SUBSCRIPTION_TIMEOUT", 30)
SUBSCRIPTION_MAX_BYTES = 10 * 1024 * 1024
KEYCHAIN_SERVICE = "fleet.subscription"
SUBSCRIPTIONS_FILE = CONFIG_DIR / "subscriptions.json"
SUPPORTED_PROTOCOLS = ("vmess", "hysteria2", "anytls", "trojan")
MIGRATION_BASELINE_COUNTS = {
    "vmess": 29,
    "hysteria2": 4,
    "anytls": 11,
    "trojan": 0,
}
MIGRATION_BASELINE_TOTAL = sum(MIGRATION_BASELINE_COUNTS.values())
PROXY_HOST = "127.0.0.1"
PROXY_PORT = _env_int("FLEET_PORT", 7890)
TUN_ADDR = "172.19.0.1/30"
TUN_IFACE = ""


class SubscriptionError(Exception):
    """A safe, user-displayable subscription failure."""

    def __init__(self, category: str, message: str):
        super().__init__(message)
        self.category = category


SUBSCRIPTION_NAME_RE = re.compile(r"^[A-Za-z0-9][A-Za-z0-9._-]{0,31}$")
SUBSCRIPTION_ID_RE = re.compile(r"^[0-9a-f]{32}$")


class SubscriptionRegistry:
    """Strict, non-secret registry for stable subscription identities."""

    def __init__(self, config_dir: Path = CONFIG_DIR):
        self.config_dir = Path(config_dir)
        self.path = self.config_dir / "subscriptions.json"
        self.revision = 0
        self.records: List[Dict[str, Any]] = []
        if self.path.exists():
            self._load()

    def _load(self) -> None:
        try:
            value = json.loads(self.path.read_text())
        except (OSError, ValueError, TypeError):
            raise SubscriptionError("registry", "Subscription registry is damaged")
        if (not isinstance(value, dict) or value.get("schema") != 2
                or isinstance(value.get("revision"), bool)
                or not isinstance(value.get("revision"), int)
                or value.get("revision", -1) < 0
                or not isinstance(value.get("subscriptions"), list)):
            raise SubscriptionError("registry", "Subscription registry has an unsupported schema")
        names = set()
        ids = set()
        allowed = {"id", "name", "status", "created_at", "removed_at"}
        records = []
        for raw in value["subscriptions"]:
            if not isinstance(raw, dict) or set(raw) - allowed:
                raise SubscriptionError("registry", "Subscription registry contains unsafe fields")
            subscription_id = raw.get("id")
            name = raw.get("name")
            status = raw.get("status")
            created_at = raw.get("created_at")
            if (not isinstance(subscription_id, str) or not SUBSCRIPTION_ID_RE.fullmatch(subscription_id)
                    or not isinstance(name, str) or not SUBSCRIPTION_NAME_RE.fullmatch(name)
                    or status not in ("active", "removed")
                    or not isinstance(created_at, str)
                    or (status == "removed" and not isinstance(raw.get("removed_at"), str))):
                raise SubscriptionError("registry", "Subscription registry contains an invalid record")
            folded = name.casefold()
            if subscription_id in ids or folded in names:
                raise SubscriptionError("registry", "Subscription registry contains duplicate identities")
            ids.add(subscription_id)
            names.add(folded)
            records.append(dict(raw))
        self.revision = value["revision"]
        self.records = records

    def save(self) -> None:
        self.revision += 1
        try:
            _atomic_json(self.path, {"schema": 2, "revision": self.revision,
                                     "subscriptions": self.records})
        except Exception:
            self.revision -= 1
            raise

    def allocate_name(self) -> str:
        used = {record["name"].casefold() for record in self.records}
        index = 1
        while f"subscription-{index}" in used:
            index += 1
        return f"subscription-{index}"

    def add(self, name: Optional[str] = None) -> Dict[str, Any]:
        name = name or self.allocate_name()
        if not SUBSCRIPTION_NAME_RE.fullmatch(name) or "/" in name:
            raise SubscriptionError("registry", "Subscription name must use 1-32 letters, digits, '.', '_' or '-'")
        if any(record["name"].casefold() == name.casefold() for record in self.records):
            raise SubscriptionError("registry", "Subscription name is already in use")
        record = {"id": uuid.uuid4().hex, "name": name, "status": "active",
                  "created_at": datetime.now(timezone.utc).isoformat()}
        self.records.append(record)
        return record

    def resolve(self, selector: str, active_only: bool = False) -> Dict[str, Any]:
        if not selector:
            raise SubscriptionError("selector", "Subscription selector is required")
        folded = selector.casefold()
        matches = [record for record in self.records
                   if record["name"].casefold() == folded
                   or record["id"] == selector
                   or record["id"].startswith(selector.lower())]
        if active_only:
            matches = [record for record in matches if record["status"] == "active"]
        if len(matches) != 1:
            message = "Subscription was not found" if not matches else "Subscription selector is ambiguous"
            raise SubscriptionError("selector", message)
        return matches[0]

    def mark_removed(self, selector: str) -> Dict[str, Any]:
        record = self.resolve(selector, active_only=True)
        record["status"] = "removed"
        record["removed_at"] = datetime.now(timezone.utc).isoformat()
        return record

    def restore_active(self, subscription_id: str) -> None:
        record = self.resolve(subscription_id)
        record["status"] = "active"
        record.pop("removed_at", None)

    def purge_removed(self) -> List[Dict[str, Any]]:
        removed = [record for record in self.records if record["status"] == "removed"]
        self.records = [record for record in self.records if record["status"] == "active"]
        return removed


def _secure_mkdir(path: Path) -> None:
    path.mkdir(parents=True, exist_ok=True, mode=0o700)
    path.chmod(0o700)


def _secure_write(path: Path, data: bytes) -> None:
    _secure_mkdir(path.parent)
    fd = os.open(path, os.O_WRONLY | os.O_CREAT | os.O_TRUNC, 0o600)
    try:
        handle = os.fdopen(fd, "wb")
        fd = -1
        with handle:
            handle.write(data)
            handle.flush()
            os.fsync(handle.fileno())
    except BaseException:
        if fd >= 0:
            os.close(fd)
        raise
    finally:
        path.chmod(0o600)


def _atomic_json(path: Path, value: Dict[str, Any]) -> None:
    _secure_mkdir(path.parent)
    fd, name = tempfile.mkstemp(prefix=f".{path.name}.", dir=path.parent)
    tmp = Path(name)
    try:
        os.chmod(name, 0o600)
        with os.fdopen(fd, "w", encoding="utf-8") as handle:
            json.dump(value, handle, ensure_ascii=False, indent=2)
            handle.flush()
            os.fsync(handle.fileno())
        os.replace(tmp, path)
        path.chmod(0o600)
        dir_fd = os.open(path.parent, os.O_RDONLY)
        try:
            os.fsync(dir_fd)
        finally:
            os.close(dir_fd)
    finally:
        if tmp.exists():
            tmp.unlink()


def _sha256(data: bytes) -> str:
    return hashlib.sha256(data).hexdigest()


def _protocol_counts(nodes: List[Dict[str, Any]]) -> Dict[str, int]:
    return {kind: sum(1 for node in nodes if node.get("type") == kind)
            for kind in SUPPORTED_PROTOCOLS}


def _normalize_protocol_counts(value: Any) -> Optional[Dict[str, int]]:
    """Normalize pre-protocol-extension manifests without hiding real data."""
    if not isinstance(value, dict):
        return None
    normalized = {}
    for kind in SUPPORTED_PROTOCOLS:
        count = value.get(kind, 0)
        if isinstance(count, bool) or not isinstance(count, int) or count < 0:
            return None
        normalized[kind] = count
    for kind, count in value.items():
        if kind not in SUPPORTED_PROTOCOLS and count != 0:
            return None
    return normalized


class GenerationStore:
    """Crash-safe immutable subscription generations with verified fallback."""

    def __init__(self, root: Path = CONFIG_DIR):
        self.root = Path(root)
        self.generations = self.root / "generations"
        self.current = self.root / "current.json"
        self.legacy = self.root / "nodes.json"
        self.last_load_fallback = False

    def publish(self, source: bytes, nodes: List[Dict[str, Any]], counts: Dict[str, int]) -> str:
        _secure_mkdir(self.root)
        _secure_mkdir(self.generations)
        generation = datetime.now(timezone.utc).strftime("%Y%m%dT%H%M%S%fZ")
        tmp = Path(tempfile.mkdtemp(prefix=".generation-", dir=self.generations))
        os.chmod(tmp, 0o700)
        nodes_data = json.dumps({"nodes": nodes, "groups": []}, ensure_ascii=False,
                                indent=2).encode()
        manifest = {
            "schema": 1, "generation": generation,
            "created_at": datetime.now(timezone.utc).isoformat(),
            "node_count": len(nodes), "protocol_counts": counts,
            "source_sha256": _sha256(source), "nodes_sha256": _sha256(nodes_data),
        }
        final = self.generations / generation
        try:
            _secure_write(tmp / "source.yaml", source)
            _secure_write(tmp / "nodes.json", nodes_data)
            _secure_write(tmp / "manifest.json", json.dumps(manifest, indent=2).encode())
            os.replace(tmp, final)
            _atomic_json(self.current, {"generation": generation})
        except Exception:
            if tmp.exists():
                shutil.rmtree(tmp, ignore_errors=True)
            if final.exists():
                shutil.rmtree(final, ignore_errors=True)
            raise
        self._cleanup(generation)
        return generation

    def _valid_generation(self, path: Path) -> Optional[tuple[List[Dict[str, Any]], str]]:
        try:
            manifest = json.loads((path / "manifest.json").read_text())
            if manifest.get("schema") != 1 or manifest.get("generation") != path.name:
                return None
            source = (path / "source.yaml").read_bytes()
            nodes_data = (path / "nodes.json").read_bytes()
            if _sha256(source) != manifest.get("source_sha256") or _sha256(nodes_data) != manifest.get("nodes_sha256"):
                return None
            payload = json.loads(nodes_data)
            nodes = payload.get("nodes") if isinstance(payload, dict) else None
            if not isinstance(nodes, list) or len(nodes) != manifest.get("node_count"):
                return None
            actual_counts = _protocol_counts(nodes)
            manifest_counts = _normalize_protocol_counts(manifest.get("protocol_counts"))
            if (sum(actual_counts.values()) != len(nodes)
                    or actual_counts != manifest_counts):
                return None
            return nodes, str(manifest.get("created_at", ""))
        except (OSError, ValueError, TypeError):
            return None

    def load_nodes(self, warn: bool = False) -> List[Dict[str, Any]]:
        self.last_load_fallback = False
        current_name = ""
        try:
            pointer = json.loads(self.current.read_text())
            candidate = pointer.get("generation") if isinstance(pointer, dict) else ""
            if isinstance(candidate, str) and re.fullmatch(r"[A-Za-z0-9._-]+", candidate):
                current_name = candidate
                valid = self._valid_generation(self.generations / candidate)
                if valid:
                    return valid[0]
        except (OSError, ValueError, TypeError):
            pass
        candidates = []
        if self.generations.exists():
            for path in self.generations.iterdir():
                if path.is_dir() and path.name != current_name and not path.name.startswith("."):
                    valid = self._valid_generation(path)
                    if valid:
                        candidates.append((valid[1], path.name, valid[0]))
        if candidates:
            self.last_load_fallback = True
            if warn:
                print("Warning: current cache failed integrity checks; using previous valid cache")
            return max(candidates, key=lambda item: (item[0], item[1]))[2]
        try:
            payload = json.loads(self.legacy.read_text())
            nodes = payload.get("nodes") if isinstance(payload, dict) else None
            if isinstance(nodes, list):
                self.last_load_fallback = True
                if warn:
                    print("Warning: using legacy node cache")
                return nodes
        except (OSError, ValueError, TypeError):
            pass
        if warn:
            print("Node cache is missing or damaged. Run 'fleet refresh'.")
        return []

    def _cleanup(self, current: str) -> None:
        valid = []
        for path in self.generations.iterdir():
            if path.is_dir() and not path.name.startswith(".") and self._valid_generation(path):
                valid.append(path)
        valid.sort(key=lambda p: p.name, reverse=True)
        for path in valid[2:]:
            if path.name != current:
                shutil.rmtree(path, ignore_errors=True)


class _PidFileLock:
    def __init__(self, path: Path):
        self.path = Path(path)

    def __enter__(self):
        _secure_mkdir(self.path.parent)
        try:
            fd = os.open(self.path, os.O_WRONLY | os.O_CREAT | os.O_EXCL, 0o600)
        except FileExistsError:
            try:
                pid = int(self.path.read_text().strip())
                os.kill(pid, 0)
            except (ValueError, OSError):
                self.path.unlink(missing_ok=True)
                fd = os.open(self.path, os.O_WRONLY | os.O_CREAT | os.O_EXCL, 0o600)
            else:
                raise SubscriptionError("lock", "Another Fleet write operation is running")
        with os.fdopen(fd, "w") as handle:
            handle.write(str(os.getpid()))
        return self

    def __exit__(self, exc_type, exc, tb):
        self.path.unlink(missing_ok=True)


class RefreshLock(_PidFileLock):
    """Legacy single lock retained for old callers and transition tests."""

    def __init__(self, root: Path):
        super().__init__(Path(root) / "refresh.lock")


class CompositeWriterLock:
    """Coordinate new writers with both legacy and current Fleet releases."""

    def __init__(self, root: Path):
        root = Path(root)
        self.legacy = _PidFileLock(root / "refresh.lock")
        self.writer = _PidFileLock(root / "writer.lock")

    def __enter__(self):
        self.legacy.__enter__()
        try:
            self.writer.__enter__()
        except BaseException:
            self.legacy.__exit__(None, None, None)
            raise
        return self

    def __exit__(self, exc_type, exc, tb):
        try:
            self.writer.__exit__(exc_type, exc, tb)
        finally:
            self.legacy.__exit__(exc_type, exc, tb)


class CredentialBackend:
    def set_url(self, subscription_id: Optional[str], url: str) -> None:
        raise NotImplementedError

    def get_url(self, subscription_id: Optional[str] = None) -> str:
        raise NotImplementedError

    def delete_url(self, subscription_id: Optional[str] = None) -> None:
        raise NotImplementedError

    def is_configured(self, subscription_id: Optional[str] = None) -> bool:
        try:
            return bool(self.get_url(subscription_id))
        except SubscriptionError:
            return False


class KeychainCredentialBackend(CredentialBackend):
    def __init__(self, runner=subprocess.run):
        self.runner = runner
        self.username = getpass.getuser()

    def _account(self, subscription_id: Optional[str]) -> str:
        if subscription_id is None:
            return self.username
        if not SUBSCRIPTION_ID_RE.fullmatch(subscription_id):
            raise SubscriptionError("credential", "Invalid subscription identity")
        return f"{self.username}:{subscription_id}"

    def _run(self, args: List[str], input_text: Optional[str] = None, check: bool = True):
        if sys.platform != "darwin":
            raise SubscriptionError("credential", "macOS Keychain is unavailable on this platform")
        result = self.runner(["/usr/bin/security", *args], input=input_text,
                             capture_output=True, text=True, timeout=15)
        if check and result.returncode != 0:
            raise SubscriptionError("credential", "Keychain operation failed")
        return result

    def set_url(self, subscription_id: Optional[str], url: str) -> None:
        self._run(["add-generic-password", "-U", "-s", KEYCHAIN_SERVICE,
                   "-a", self._account(subscription_id), "-w", url])

    def get_url(self, subscription_id: Optional[str] = None) -> str:
        result = self._run(["find-generic-password", "-s", KEYCHAIN_SERVICE,
                            "-a", self._account(subscription_id), "-w"], check=False)
        if result.returncode != 0 or not result.stdout.strip():
            raise SubscriptionError("credential", "Subscription is not configured")
        return result.stdout.strip()

    def delete_url(self, subscription_id: Optional[str] = None) -> None:
        result = self._run(["delete-generic-password", "-s", KEYCHAIN_SERVICE,
                            "-a", self._account(subscription_id)], check=False)
        if result.returncode not in (0, 44):
            raise SubscriptionError("credential", "Keychain operation failed")


def validate_subscription_url(url: str) -> str:
    value = url.strip()
    parsed = urllib.parse.urlsplit(value)
    if parsed.scheme != "https" or not parsed.hostname or parsed.username or parsed.password:
        raise SubscriptionError("credential", "A valid HTTPS subscription URL is required")
    return value


def validate_nodes(nodes: Any) -> tuple[List[Dict[str, Any]], Dict[str, int]]:
    if not isinstance(nodes, list) or not nodes:
        raise SubscriptionError("structure", "Subscription contains no proxy nodes")
    names = set()
    counts = {kind: 0 for kind in SUPPORTED_PROTOCOLS}
    for node in nodes:
        if not isinstance(node, dict):
            raise SubscriptionError("node", "A proxy node is not an object")
        name, server, kind, port = (node.get("name"), node.get("server"),
                                    node.get("type"), node.get("port"))
        if not isinstance(name, str) or not name.strip() or name in names:
            raise SubscriptionError("node", "Proxy node names must be non-empty and unique")
        names.add(name)
        if not isinstance(server, str) or not server.strip():
            raise SubscriptionError("node", "A proxy node has an invalid server")
        if kind not in SUPPORTED_PROTOCOLS:
            raise SubscriptionError("protocol", "Subscription contains an unsupported protocol")
        if isinstance(port, bool) or not isinstance(port, int) or not 1 <= port <= 65535:
            raise SubscriptionError("node", "A proxy node has an invalid port")
        secret = "uuid" if kind == "vmess" else "password"
        if not isinstance(node.get(secret), str) or not node[secret].strip():
            raise SubscriptionError("node", f"A {kind} node is missing required credentials")
        if "skip-cert-verify" in node and not isinstance(node["skip-cert-verify"], bool):
            raise SubscriptionError("node", "skip-cert-verify must be boolean")
        if kind == "vmess":
            if "alterId" in node and (isinstance(node["alterId"], bool) or not isinstance(node["alterId"], int)):
                raise SubscriptionError("node", "alterId must be an integer")
            if node.get("network") == "ws" and "ws-opts" in node and not isinstance(node["ws-opts"], dict):
                raise SubscriptionError("node", "ws-opts must be an object")
        if kind == "anytls" and "alpn" in node and (not isinstance(node["alpn"], list) or not all(isinstance(v, str) for v in node["alpn"])):
            raise SubscriptionError("node", "alpn must be a list of strings")
        if kind == "trojan":
            if "sni" in node and (not isinstance(node["sni"], str) or not node["sni"].strip()):
                raise SubscriptionError("node", "Trojan sni must be a non-empty string")
            if "tls" in node and node["tls"] is not True:
                raise SubscriptionError("node", "Trojan tls must be enabled")
            if "alpn" in node and (not isinstance(node["alpn"], list)
                    or not all(isinstance(value, str) and value.strip()
                               for value in node["alpn"])):
                raise SubscriptionError("node", "Trojan alpn must be a list of non-empty strings")
            if "network" in node and node["network"] != "tcp":
                raise SubscriptionError("node", "Trojan only supports the tcp network")
            unsupported = ("ws-opts", "grpc-opts", "http-opts", "h2-opts",
                           "http-upgrade-opts", "reality-opts", "ech-opts",
                           "client-fingerprint")
            if any(field in node for field in unsupported):
                raise SubscriptionError("node", "Trojan transport options are not supported")
        for field in ("up", "down"):
            if kind == "hysteria2" and field in node and (isinstance(node[field], bool) or not isinstance(node[field], (int, float)) or node[field] <= 0):
                raise SubscriptionError("node", f"{field} must be positive")
        counts[kind] += 1
    return nodes, counts


def enforce_node_count(new_count: int, previous_count: int, force: bool) -> None:
    if new_count < 1:
        raise SubscriptionError("quantity", "Subscription contains no valid nodes")
    if previous_count and new_count < previous_count * 0.5 and not force:
        raise SubscriptionError("quantity", f"Node count shrank from {previous_count} to {new_count}; use --force to accept")


def _parse_subscription_yaml_strict(path: Path) -> Dict[str, Any]:
    script = r'''require "json"
require "yaml"
content = File.read(ARGV[0])
data = YAML.safe_load(content, permitted_classes: [], permitted_symbols: [], aliases: true)
puts JSON.generate(data || {})'''
    try:
        result = subprocess.run(["/usr/bin/ruby", "-e", script, str(path)],
                                capture_output=True, text=True, timeout=20)
    except (OSError, subprocess.SubprocessError):
        raise SubscriptionError("yaml", "Strict YAML parser is unavailable")
    if result.returncode != 0:
        raise SubscriptionError("yaml", "Subscription YAML is invalid")
    try:
        data = json.loads(result.stdout)
    except ValueError:
        raise SubscriptionError("yaml", "Subscription YAML produced invalid data")
    if not isinstance(data, dict):
        raise SubscriptionError(
            "format",
            "Subscription response is not supported Clash YAML; check format negotiation",
        )
    if not isinstance(data.get("proxies"), list):
        raise SubscriptionError("structure", "Subscription must contain a proxies list")
    return data


class HttpsOnlyRedirectHandler(urllib.request.HTTPRedirectHandler):
    def redirect_request(self, req, fp, code, msg, headers, newurl):
        if urllib.parse.urlsplit(newurl).scheme != "https":
            raise SubscriptionError("network", "Subscription redirect was rejected")
        return super().redirect_request(req, fp, code, msg, headers, newurl)


def download_subscription(url: str, opener=None, timeout: int = SUBSCRIPTION_TIMEOUT_SECONDS) -> bytes:
    url = validate_subscription_url(url)
    opener = opener or urllib.request.build_opener(HttpsOnlyRedirectHandler())
    request = urllib.request.Request(url, headers={"User-Agent": SUBSCRIPTION_USER_AGENT})
    try:
        with opener.open(request, timeout=timeout) as response:
            status = getattr(response, "status", 200)
            if not 200 <= status < 300:
                raise SubscriptionError("http", f"Subscription server returned HTTP {status}")
            data = response.read(SUBSCRIPTION_MAX_BYTES + 1)
    except SubscriptionError:
        raise
    except (urllib.error.URLError, OSError, TimeoutError):
        raise SubscriptionError("network", "Subscription download failed")
    if not data:
        raise SubscriptionError("http", "Subscription response was empty")
    if len(data) > SUBSCRIPTION_MAX_BYTES:
        raise SubscriptionError("http", "Subscription response was too large")
    return data


def validate_with_sing_box(nodes: List[Dict[str, Any]], binary: str = SING_BOX_BIN) -> None:
    if not Path(binary).exists():
        raise SubscriptionError("sing-box", "sing-box is not installed")
    with tempfile.TemporaryDirectory(prefix="fleet-check-") as tmp:
        for index, node in enumerate(nodes):
            path = Path(tmp) / f"node-{index}.json"
            path.write_text(json.dumps(mk_proxy_config(node)))
            result = subprocess.run([binary, "check", "-c", str(path)], capture_output=True,
                                    text=True, timeout=30)
            if result.returncode != 0:
                name = node.get("name") or index
                raise SubscriptionError("sing-box", f"Node '{name}' failed sing-box validation")


# ═══════════════════════════════════════════════════════════════════════════════
# sing-box config generator
# ═══════════════════════════════════════════════════════════════════════════════

def _build_outbound(node: Dict) -> Dict[str, Any]:
    """Build the proxy outbound section for a node."""
    node_type = node.get("type", "vmess")
    server = node.get("server", "")
    port = node.get("port", 443)
    outbound: Dict[str, Any] = {"tag": "proxy"}

    if node_type == "vmess":
        outbound.update({"type": "vmess", "server": server, "server_port": port,
                         "uuid": node.get("uuid", ""), "security": node.get("cipher", "auto"),
                         "alter_id": node.get("alterId", 0)})
        network = node.get("network", "")
        if network == "ws":
            transport: Dict[str, Any] = {"type": "ws"}
            ws_opts = node.get("ws-opts") or {}
            if not isinstance(ws_opts, dict):
                ws_opts = {}
            transport["path"] = (ws_opts.get("path") or node.get("ws-path") or "/")
            if not transport.get("path"):
                transport["path"] = "/"
            ws_headers = {}
            for src in [node.get("ws-headers", {}), ws_opts.get("headers", {})]:
                if isinstance(src, dict):
                    ws_headers.update({k: v for k, v in src.items() if isinstance(v, str)})
            if not ws_headers and "Host" in node:
                ws_headers["Host"] = node["Host"]
            if ws_headers:
                transport["headers"] = ws_headers
            outbound["transport"] = transport

    elif node_type == "hysteria2":
        outbound.update({"type": "hysteria2", "server": server, "server_port": port,
                         "password": node.get("password", ""),
                         "tls": {"enabled": True, "server_name": node.get("sni", server),
                                 "insecure": node.get("skip-cert-verify", False)}})
        if node.get("down"):
            outbound["down_mbps"] = node["down"]
        if node.get("up"):
            outbound["up_mbps"] = node["up"]

    elif node_type == "anytls":
        tls: Dict[str, Any] = {"enabled": True,
                               "server_name": node.get("sni", server),
                               "insecure": node.get("skip-cert-verify", False)}
        if isinstance(node.get("alpn"), list):
            tls["alpn"] = node["alpn"]
        fingerprint = node.get("client-fingerprint")
        if fingerprint:
            tls["utls"] = {"enabled": True, "fingerprint": fingerprint}
        outbound.update({"type": "anytls", "server": server, "server_port": port,
                         "password": node.get("password", ""), "tls": tls})

    elif node_type == "trojan":
        tls = {"enabled": True,
               "server_name": node.get("sni") or server,
               "insecure": node.get("skip-cert-verify", False)}
        if node.get("alpn"):
            tls["alpn"] = node["alpn"]
        outbound.update({"type": "trojan", "server": server, "server_port": port,
                         "password": node.get("password", ""), "tls": tls})

    else:
        raise SubscriptionError("protocol", "Unsupported proxy protocol")

    return outbound


def _base_route() -> Dict:
    return {"rules": [], "auto_detect_interface": True}


def mk_proxy_config(node: Dict) -> Dict:
    """Config for proxy mode: HTTP/SOCKS inbound only."""
    return {
        "log": {"level": "warn"},
        "inbounds": [{"type": "mixed", "tag": "mixed-in", "listen": PROXY_HOST,
                       "listen_port": PROXY_PORT}],
        "outbounds": [_build_outbound(node), {"type": "direct", "tag": "direct"}],
        "route": {**_base_route(), "rules": [{"inbound": "mixed-in", "outbound": "proxy"}]},
    }


def mk_tun_config(node: Dict) -> Dict:
    """Config for TUN mode (needs ENABLE_DEPRECATED_LEGACY_DNS_SERVERS=true).

    DNS: system resolver for bootstrapping, 1.1.1.1 via proxy for remote.
    TUN + HTTP/SOCKS run simultaneously — browser + CLI + Docker all work.
    """
    return {
        "log": {"level": "warn"},
        "dns": {
            "servers": [
                {"tag": "dns-remote", "address": "https://1.1.1.1/dns-query",
                 "detour": "proxy"},
                {"tag": "dns-local", "address": "local", "detour": "direct"},
            ],
            "rules": [
                {"outbound": "any", "server": "dns-local"},
            ],
            "final": "dns-remote",
            "strategy": "ipv4_only",
            "reverse_mapping": True,
        },
        "inbounds": [
            {"type": "tun", "tag": "tun-in", "address": [TUN_ADDR], "mtu": 9000,
             "auto_route": True, "strict_route": True, "stack": "system"},
            {"type": "mixed", "tag": "mixed-in", "listen": PROXY_HOST,
             "listen_port": PROXY_PORT},
        ],
        "outbounds": [
            _build_outbound(node),
            {"type": "direct", "tag": "direct"},
        ],
        "route": {
            **_base_route(),
            "default_domain_resolver": "dns-local",
            "rules": [
                {"inbound": "tun-in", "outbound": "proxy"},
                {"inbound": "mixed-in", "outbound": "proxy"},
            ],
        },
    }


# ═══════════════════════════════════════════════════════════════════════════════
# Process management
# ═══════════════════════════════════════════════════════════════════════════════

PROXY_KINDS = {
    "http": {
        "get": "-getwebproxy",
        "set": "-setwebproxy",
        "state": "-setwebproxystate",
    },
    "https": {
        "get": "-getsecurewebproxy",
        "set": "-setsecurewebproxy",
        "state": "-setsecurewebproxystate",
    },
    "socks": {
        "get": "-getsocksfirewallproxy",
        "set": "-setsocksfirewallproxy",
        "state": "-setsocksfirewallproxystate",
    },
}


def _run_networksetup(args: List[str], warn: bool = True) -> bool:
    if sys.platform != "darwin":
        return True
    try:
        result = subprocess.run(["networksetup", *args], capture_output=True,
                                text=True, timeout=10)
    except Exception as exc:
        if warn:
            print(f"Warning: networksetup failed: {exc}")
        return False
    if result.returncode != 0:
        if warn:
            msg = (result.stderr or result.stdout).strip()
            print(f"Warning: networksetup {' '.join(args)} failed: {msg}")
        return False
    return True


def _network_services() -> List[str]:
    if sys.platform != "darwin":
        return []
    try:
        result = subprocess.run(["networksetup", "-listallnetworkservices"],
                                capture_output=True, text=True, timeout=10)
    except Exception:
        return []
    if result.returncode != 0:
        return []

    services = []
    for line in result.stdout.splitlines():
        service = line.strip()
        if not service or service.startswith("An asterisk"):
            continue
        if service.startswith("*"):
            continue
        services.append(service)
    return services


def _parse_proxy_output(text: str) -> Dict[str, Any]:
    data: Dict[str, Any] = {"enabled": False, "server": "", "port": ""}
    for line in text.splitlines():
        key, sep, value = line.partition(":")
        if not sep:
            continue
        key = key.strip()
        value = value.strip()
        if key == "Enabled":
            data["enabled"] = value == "Yes"
        elif key == "Server":
            data["server"] = value
        elif key == "Port":
            data["port"] = value
    return data


def _get_proxy_setting(service: str, kind: str) -> Dict[str, Any]:
    spec = PROXY_KINDS[kind]
    try:
        result = subprocess.run(["networksetup", spec["get"], service],
                                capture_output=True, text=True, timeout=10)
    except Exception:
        return {"enabled": False, "server": "", "port": ""}
    if result.returncode != 0:
        return {"enabled": False, "server": "", "port": ""}
    return _parse_proxy_output(result.stdout)


def _system_proxy_snapshot() -> Dict[str, Any]:
    if sys.platform != "darwin":
        return {}
    return {
        service: {
            kind: _get_proxy_setting(service, kind)
            for kind in PROXY_KINDS
        }
        for service in _network_services()
    }


def _set_proxy_setting(service: str, kind: str, setting: Dict[str, Any]) -> bool:
    spec = PROXY_KINDS[kind]
    enabled = bool(setting.get("enabled"))
    server = str(setting.get("server") or "")
    port = str(setting.get("port") or "")
    ok = True
    if server and port and port != "0":
        ok = _run_networksetup([spec["set"], service, server, port]) and ok
    ok = _run_networksetup([spec["state"], service, "on" if enabled else "off"]) and ok
    return ok


def _enable_system_proxies() -> bool:
    ok = True
    for service in _network_services():
        for kind, spec in PROXY_KINDS.items():
            ok = _run_networksetup([spec["set"], service, PROXY_HOST, str(PROXY_PORT)]) and ok
            ok = _run_networksetup([spec["state"], service, "on"]) and ok
    return ok


def _disable_own_system_proxies() -> bool:
    owner = _port_owner(PROXY_PORT)
    if owner and "sing-box" not in owner:
        return True

    ok = True
    for service in _network_services():
        for kind, spec in PROXY_KINDS.items():
            current = _get_proxy_setting(service, kind)
            if current.get("server") == PROXY_HOST and str(current.get("port")) == str(PROXY_PORT):
                ok = _run_networksetup([spec["state"], service, "off"]) and ok
    return ok


def _restore_system_proxies(snapshot: Optional[Dict[str, Any]]) -> bool:
    if not snapshot:
        return _disable_own_system_proxies()

    ok = True
    current_services = set(_network_services())
    for service, settings in snapshot.items():
        if service not in current_services:
            continue
        for kind, setting in settings.items():
            if kind in PROXY_KINDS and isinstance(setting, dict):
                ok = _set_proxy_setting(service, kind, setting) and ok
    return ok


def _system_proxy_summary() -> str:
    snapshot = _system_proxy_snapshot()
    enabled = []
    for service, settings in snapshot.items():
        for kind, setting in settings.items():
            if setting.get("enabled"):
                server = setting.get("server") or "?"
                port = setting.get("port") or "?"
                enabled.append(f"{service}/{kind}={server}:{port}")
    if not enabled:
        return "OFF"
    own = all(item.endswith(f"={PROXY_HOST}:{PROXY_PORT}") for item in enabled)
    return f"ON ({PROXY_HOST}:{PROXY_PORT})" if own else "ON (custom proxy settings)"


def _port_is_available(host: str, port: int) -> bool:
    with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as sock:
        try:
            sock.bind((host, port))
        except OSError:
            return False
    return True


def _port_owner(port: int) -> str:
    try:
        result = subprocess.run(["lsof", "-nP", f"-iTCP:{port}", "-sTCP:LISTEN"],
                                capture_output=True, text=True, timeout=10)
    except Exception:
        return ""
    for line in result.stdout.splitlines()[1:]:
        parts = line.split()
        if len(parts) >= 2:
            return f"{parts[0]} (PID {parts[1]})"

    try:
        result = subprocess.run(["netstat", "-anv", "-p", "tcp"],
                                capture_output=True, text=True, timeout=10)
    except Exception:
        return ""
    marker = f".{port}"
    for line in result.stdout.splitlines():
        if marker not in line or "LISTEN" not in line:
            continue
        tail = line.split("LISTEN", 1)[1]
        for token in tail.split():
            if ":" not in token:
                continue
            name, pid = token.rsplit(":", 1)
            if pid.isdigit() and name != "process":
                return f"{name} (PID {pid})"
    return ""


def _print_log_tail(path: Path, lines: int = 20):
    if not path.exists():
        return
    content = path.read_text(errors="replace").splitlines()
    if not content:
        return
    print(f"  Last log lines:")
    for line in content[-lines:]:
        print(f"    {line}")


def _find_singbox() -> Optional[int]:
    try:
        result = subprocess.run(["ps", "-axo", "pid=,comm=,args="],
                                capture_output=True, text=True, timeout=10)
        if result.returncode != 0:
            return None
        config_dir = str(CONFIG_DIR)
        for line in result.stdout.splitlines():
            parts = line.strip().split(None, 2)
            if len(parts) < 3:
                continue
            pid_s, _comm, args = parts
            argv0 = Path(args.split()[0]).name if args.split() else ""
            if argv0 == "sing-box" and config_dir in args:
                return int(pid_s)
    except Exception:
        pass
    return None


def _save_state(mode: str, node: Any, system_proxy_before: Optional[Dict[str, Any]] = None):
    CONFIG_DIR.mkdir(parents=True, exist_ok=True)
    if isinstance(node, dict):
        metadata = node.get("_fleet", {})
        node_name = node.get("name", "")
        state = {"mode": mode, "node": node_name, "node_name": node_name,
                 "node_key": metadata.get("node_key", node_name),
                 "subscription_id": metadata.get("subscription_id"),
                 "subscription_name": metadata.get("subscription_name"),
                 "pid": _find_singbox(), "port": PROXY_PORT}
    else:
        state = {"mode": mode, "node": str(node), "node_name": str(node),
                 "node_key": str(node), "pid": _find_singbox(), "port": PROXY_PORT}
    if system_proxy_before is not None:
        state["system_proxy_before"] = system_proxy_before
    STATE_FILE.write_text(json.dumps(state, indent=2))


def _load_state() -> Optional[Dict]:
    if STATE_FILE.exists():
        try:
            return json.loads(STATE_FILE.read_text())
        except Exception:
            pass
    return None


def _stop(mode_hint: Optional[str] = None):
    """Stop sing-box. Uses sudo if running as root (TUN mode)."""
    state = _load_state()
    pid = _find_singbox()
    if pid:
        # Check if sing-box is running as root
        try:
            result = subprocess.run(["ps", "-o", "user=", "-p", str(pid)],
                                    capture_output=True, text=True)
            is_root = result.stdout.strip() == "root"
        except Exception:
            is_root = False

        if is_root and os.geteuid() != 0:
            sudo_check = subprocess.run(["sudo", "-n", "true"],
                                        capture_output=True, text=True)
            if sudo_check.returncode != 0:
                print(f"Root-owned sing-box is running (PID {pid}).")
                print("Run this to stop TUN mode:")
                print("  sudo fleet stop")
                return
            kill_cmd = ["sudo", "-n", "kill"]
        else:
            kill_cmd = ["kill"]
        try:
            subprocess.run(kill_cmd + [str(pid)], timeout=5)
            time.sleep(1)
            if _find_singbox():
                subprocess.run(kill_cmd + ["-9", str(pid)], timeout=5)
        except Exception:
            pass

    system_proxy_before = None
    if isinstance(state, dict):
        system_proxy_before = state.get("system_proxy_before")
    _restore_system_proxies(system_proxy_before)

    if STATE_FILE.exists():
        STATE_FILE.unlink()


def _start(node: Dict, mode: str, system_proxy_before: Optional[Dict[str, Any]] = None) -> bool:
    """Start sing-box with the given node and mode. Returns True on success."""
    CONFIG_DIR.mkdir(parents=True, exist_ok=True)
    if not Path(SING_BOX_BIN).exists():
        print(f"sing-box not found: {SING_BOX_BIN}")
        print("Install it with: brew install sing-box")
        return False
    owner = _port_owner(PROXY_PORT)
    if owner:
        print(f"Port in use: {PROXY_HOST}:{PROXY_PORT}")
        print(f"Owner: {owner}")
        print("Stop the owner first, or choose another port with:")
        print("  FLEET_PORT=7891 fleet start <node>")
        return False

    config = mk_tun_config(node) if mode == "tun" else mk_proxy_config(node)
    SING_BOX_CONFIG.write_text(json.dumps(config, indent=2))

    # Validate (TUN may need legacy DNS compat env)
    check_env = os.environ.copy()
    if mode == "tun":
        check_env["ENABLE_DEPRECATED_LEGACY_DNS_SERVERS"] = "true"
        check_env["ENABLE_DEPRECATED_OUTBOUND_DNS_RULE_ITEM"] = "true"
    result = subprocess.run([SING_BOX_BIN, "check", "-c", str(SING_BOX_CONFIG)],
                            capture_output=True, text=True, env=check_env)
    if result.returncode != 0:
        print(f"Config error:\n{result.stderr}")
        return False

    # Build command
    cmd = [SING_BOX_BIN, "run", "-c", str(SING_BOX_CONFIG), "-D", str(CONFIG_DIR)]

    if mode == "tun":
        tun_env_vars = ("ENABLE_DEPRECATED_LEGACY_DNS_SERVERS=true "
                        "ENABLE_DEPRECATED_OUTBOUND_DNS_RULE_ITEM=true")
        tun_cmd = " ".join(f"'{c}'" if ' ' in str(c) else str(c) for c in cmd)
        full_cmd = f"sudo env {tun_env_vars} {tun_cmd}"
        start_script = CONFIG_DIR / "start-tun.sh"
        start_script.write_text(f"#!/bin/bash\nexec {full_cmd}\n")
        start_script.chmod(0o755)

        print("Requesting sudo to start TUN mode...")
        try:
            sudo_result = subprocess.run(["sudo", "-v"], timeout=60)
        except Exception:
            sudo_result = subprocess.CompletedProcess(["sudo", "-v"], 1)
        if sudo_result.returncode != 0:
            print("Could not obtain sudo credentials.")
            print("Run this in your terminal instead:")
            print("")
            print(f"  {start_script}")
            print("")
            return False

        run_cmd = ["sudo", "-n", "env",
                   "ENABLE_DEPRECATED_LEGACY_DNS_SERVERS=true",
                   "ENABLE_DEPRECATED_OUTBOUND_DNS_RULE_ITEM=true",
                   *cmd]
        with open(SING_BOX_LOG, "w") as log:
            subprocess.Popen(run_cmd, stdout=log, stderr=log, start_new_session=True)
    else:
        with open(SING_BOX_LOG, "w") as log:
            subprocess.Popen(cmd, stdout=log, stderr=log, start_new_session=True)

    time.sleep(3 if mode == "tun" else 2)
    pid = _find_singbox()
    if pid:
        if mode == "proxy":
            _enable_system_proxies()
        _save_state(mode, node, system_proxy_before)
        return True
    return False


# ═══════════════════════════════════════════════════════════════════════════════
# Commands
# ═══════════════════════════════════════════════════════════════════════════════

def cmd_list(nodes: List[Dict]):
    state = _load_state()
    current = state.get("node_key", state.get("node")) if state else None
    mode = state.get("mode", "") if state else ""

    header = f"{'':4s} {'NODE':30s} {'SOURCE':20s} {'STATE':8s} {'TYPE':10s} {'SERVER'}"
    print(header)
    print("-" * 80)
    for i, node in enumerate(nodes):
        metadata = node.get("_fleet", {})
        marker = "→" if metadata.get("node_key", node["name"]) == current else " "
        source = metadata.get("subscription_name", "legacy")
        status = metadata.get("subscription_status", "active")
        print(f"{marker} {i:2d} {node['name']:30s} {source:20s} {status:8s} "
              f"{node.get('type','vmess'):10s} {node.get('server','?'):30s}")
    print("-" * 80)
    print(f"Total: {len(nodes)} nodes")
    if state:
        print(f"Mode: {mode}  |  Node: {current}  |  PID: {state.get('pid','?')}")
    else:
        print("Not running")
    return 0


def cmd_status():
    state = _load_state()
    pid = _find_singbox()
    system_proxy = _system_proxy_summary()

    if pid and state:
        print(f"Mode:    {state.get('mode', '?')}")
        print(f"Status:  RUNNING (PID {pid})")
        print(f"Node:    {state['node']}")
        print(f"Port:    {PROXY_HOST}:{PROXY_PORT} (HTTP + SOCKS5)")
        print(f"System:  macOS proxy {system_proxy}")
        if state.get("mode") == "tun":
            print(f"TUN:     {TUN_ADDR}")
        _test_proxy()
    elif pid:
        print(f"Status: RUNNING (PID {pid}) — state missing")
        print(f"System: macOS proxy {system_proxy}")
    else:
        print("Status: STOPPED")
        print(f"System: macOS proxy {system_proxy}")
        if state:
            print(f"Last:   {state['node']} ({state.get('mode','?')})")
    return 0


def cmd_start(nodes: List[Dict], target: str, mode: str = "proxy"):
    _stop()
    node = _find_node(nodes, target)
    if not node:
        return 1
    system_proxy_before = _system_proxy_snapshot() if mode == "proxy" else None
    if mode == "tun":
        print(f"Starting TUN mode with: {node['name']}")
        print("(sudo may prompt for password)")
    else:
        print(f"Starting proxy mode with: {node['name']}")
    if _start(node, mode, system_proxy_before):
        if mode == "tun":
            print(f"  HTTP/SOCKS: {PROXY_HOST}:{PROXY_PORT}")
            print(f"  TUN: {TUN_ADDR} (system-wide)")
            print(f"  System: macOS proxy unchanged")
            print(f"  Docker containers: auto-proxied ✓")
        else:
            pid = _find_singbox()
            print(f"✓ {mode} mode started (PID {pid}) — {node['name']}")
            print(f"  HTTP/SOCKS: {PROXY_HOST}:{PROXY_PORT}")
            print(f"  System: macOS proxy enabled")
            _test_proxy()
    else:
        print(f"✗ Failed to start {mode} mode")
        print(f"  Log: cat {SING_BOX_LOG}")
        _print_log_tail(SING_BOX_LOG)
        return 1
    return 0


def cmd_stop():
    state = _load_state()
    pid = _find_singbox()
    _stop()
    print("✓ Stopped and restored system proxy" if state or pid else "System proxy cleaned")
    return 0


def cmd_switch(nodes: List[Dict], target: str, mode: Optional[str] = None):
    """Switch node in the given mode, or auto-detect active mode."""
    if not mode:
        state = _load_state()
        mode = state.get("mode", "proxy") if state else "proxy"

    node = _find_node(nodes, target)
    if not node:
        return 1

    print(f"Switching [{mode}] → {node['name']}")
    _stop()
    system_proxy_before = _system_proxy_snapshot() if mode == "proxy" else None
    if _start(node, mode, system_proxy_before):
        pid = _find_singbox()
        print(f"✓ Switched (PID {pid})")
        _test_proxy()
    else:
        print("✗ Failed")
        return 1
    return 0


def _read_subscription_state(config_dir: Path = CONFIG_DIR) -> Dict[str, Any]:
    try:
        value = json.loads((config_dir / "subscription-state.json").read_text())
        return value if isinstance(value, dict) else {}
    except (OSError, ValueError):
        return {}


def _write_subscription_state(value: Dict[str, Any], config_dir: Path = CONFIG_DIR) -> None:
    _atomic_json(config_dir / "subscription-state.json", value)


def _subscription_root(config_dir: Path, subscription_id: str) -> Path:
    if not SUBSCRIPTION_ID_RE.fullmatch(subscription_id):
        raise SubscriptionError("registry", "Invalid subscription identity")
    return Path(config_dir) / "subscriptions" / subscription_id


def _read_record_state(config_dir: Path, subscription_id: str) -> Dict[str, Any]:
    try:
        value = json.loads((_subscription_root(config_dir, subscription_id) / "state.json").read_text())
        return value if isinstance(value, dict) else {}
    except (OSError, ValueError, TypeError):
        return {}


def _write_record_state(config_dir: Path, subscription_id: str,
                        value: Dict[str, Any]) -> None:
    safe = {key: item for key, item in value.items()
            if key in {"schema", "last_attempt", "last_success", "last_error",
                       "generation", "node_count", "protocol_counts"}}
    _atomic_json(_subscription_root(config_dir, subscription_id) / "state.json", safe)


def _legacy_store_exists(config_dir: Path) -> bool:
    root = Path(config_dir)
    return any((root / name).exists() for name in
               ("current.json", "nodes.json", "generations", "subscription-state.json"))


def _copy_legacy_store(config_dir: Path, target: Path) -> None:
    _secure_mkdir(target)
    for name in ("current.json", "nodes.json"):
        source = Path(config_dir) / name
        if source.exists():
            _secure_write(target / name, source.read_bytes())
    source_generations = Path(config_dir) / "generations"
    if source_generations.exists():
        shutil.copytree(source_generations, target / "generations")
    legacy_state = _read_subscription_state(Path(config_dir))
    if legacy_state:
        _write_record_state(Path(config_dir), target.name, legacy_state)


def _ensure_registry_migrated(backend: CredentialBackend, config_dir: Path,
                              name: Optional[str] = None,
                              allow_uncredentialed_legacy: bool = False) -> SubscriptionRegistry:
    """Migrate legacy identity/cache once, committing the registry last."""
    config_dir = Path(config_dir)
    if (config_dir / "subscriptions.json").exists():
        return SubscriptionRegistry(config_dir)
    registry = SubscriptionRegistry(config_dir)
    try:
        legacy_url = backend.get_url(None)
    except SubscriptionError:
        legacy_url = None
    if not legacy_url:
        if _legacy_store_exists(config_dir):
            if allow_uncredentialed_legacy:
                return registry
            raise SubscriptionError(
                "migration",
                "Legacy cache has no credential; run 'fleet subscription migrate --url URL'",
            )
        return registry
    record = registry.add(name)
    target = _subscription_root(config_dir, record["id"])
    credential_created = False
    try:
        backend.set_url(record["id"], validate_subscription_url(legacy_url))
        credential_created = True
        if _legacy_store_exists(config_dir):
            _copy_legacy_store(config_dir, target)
        registry.save()
        return registry
    except Exception:
        if credential_created:
            try:
                backend.delete_url(record["id"])
            except Exception:
                pass
        if target.exists():
            shutil.rmtree(target, ignore_errors=True)
        raise


def load_aggregated_nodes(registry: Optional[SubscriptionRegistry] = None,
                          config_dir: Path = CONFIG_DIR,
                          warn: bool = True) -> List[Dict[str, Any]]:
    registry = registry or SubscriptionRegistry(config_dir)
    result = []
    for record in registry.records:
        store = GenerationStore(_subscription_root(config_dir, record["id"]))
        nodes = store.load_nodes(warn=False)
        if store.last_load_fallback and warn:
            print(f"Warning: {record['name']} current cache is damaged; using a fallback cache")
        if not nodes and warn:
            print(f"Warning: no usable cache for subscription {record['name']}")
        for source in nodes:
            if not isinstance(source, dict):
                continue
            node = dict(source)
            node["_fleet"] = {
                "subscription_id": record["id"],
                "subscription_name": record["name"],
                "subscription_status": record["status"],
                "node_key": f"{record['id']}:{node.get('name', '')}",
            }
            result.append(node)
    return result


def _process_subscription(source: bytes, store: GenerationStore, force: bool,
                          check_sing_box=True) -> tuple:
    with tempfile.TemporaryDirectory(prefix="fleet-subscription-") as tmp:
        path = Path(tmp) / "source.yaml"
        path.write_bytes(source)
        config = _parse_subscription_yaml_strict(path)
    nodes, counts = validate_nodes(config["proxies"])
    previous = len(store.load_nodes())
    enforce_node_count(len(nodes), previous, force)
    if check_sing_box:
        validate_with_sing_box(nodes)
    generation = store.publish(source, nodes, counts)
    return generation, nodes, counts


def cmd_refresh(force: bool = False, backend: Optional[CredentialBackend] = None,
                config_dir: Path = CONFIG_DIR, selector: Optional[str] = None) -> int:
    backend = backend or KeychainCredentialBackend()
    failures = 0
    successes = 0
    try:
        with CompositeWriterLock(config_dir):
            registry = _ensure_registry_migrated(backend, config_dir)
            if selector:
                targets = [registry.resolve(selector, active_only=True)]
            else:
                targets = [record for record in registry.records if record["status"] == "active"]
            for record in targets:
                attempted = datetime.now(timezone.utc).isoformat()
                try:
                    source = download_subscription(backend.get_url(record["id"]))
                    store = GenerationStore(_subscription_root(config_dir, record["id"]))
                    generation, nodes, counts = _process_subscription(source, store, force)
                    _write_record_state(config_dir, record["id"], {
                        "schema": 1, "last_attempt": attempted, "last_success": attempted,
                        "generation": generation, "node_count": len(nodes),
                        "protocol_counts": counts,
                    })
                    successes += 1
                    print(f"✓ {record['name']}: refreshed {len(nodes)} nodes")
                except (OSError, SubscriptionError) as exc:
                    category = exc.category if isinstance(exc, SubscriptionError) else "cache"
                    state = _read_record_state(config_dir, record["id"])
                    state.update({"schema": 1, "last_attempt": attempted,
                                  "last_error": category})
                    try:
                        _write_record_state(config_dir, record["id"], state)
                    except OSError:
                        pass
                    failures += 1
                    message = str(exc) if isinstance(exc, SubscriptionError) else "local cache operation failed"
                    print(f"✗ {record['name']} [{category}]: {message}")
            removed = registry.purge_removed()
            if removed:
                registry.save()
                for record in removed:
                    shutil.rmtree(_subscription_root(config_dir, record["id"]), ignore_errors=True)
                    try:
                        backend.delete_url(record["id"])
                    except SubscriptionError:
                        pass
            elif not registry.path.exists():
                registry.save()
        print(f"Refresh complete: {successes} succeeded, {failures} failed")
        return 1 if failures else 0
    except (OSError, SubscriptionError) as exc:
        category = exc.category if isinstance(exc, SubscriptionError) else "registry"
        print(f"Refresh failed [{category}]: {exc}")
        return 1


def cmd_subscription_add(name: Optional[str] = None, url: Optional[str] = None,
                         backend: Optional[CredentialBackend] = None,
                         config_dir: Path = CONFIG_DIR) -> int:
    backend = backend or KeychainCredentialBackend()
    if name and url is None and name.strip().lower().startswith("https://"):
        url, name = name, None
    if not url:
        url = sys.stdin.readline().strip()
    try:
        validated = validate_subscription_url(url or "")
        with CompositeWriterLock(config_dir):
            registry = _ensure_registry_migrated(backend, config_dir)
            record = registry.add(name)
            backend.set_url(record["id"], validated)
            try:
                registry.save()
            except Exception:
                try:
                    backend.delete_url(record["id"])
                except Exception:
                    pass
                raise
        print(f"✓ Subscription added: {record['name']} (ID: {record['id'][:8]})")
        return 0
    except (OSError, SubscriptionError) as exc:
        category = exc.category if isinstance(exc, SubscriptionError) else "registry"
        print(f"Subscription add failed [{category}]: {exc}")
        return 1


def cmd_subscription_status(selector: Optional[str] = None,
                            backend: Optional[CredentialBackend] = None,
                            config_dir: Path = CONFIG_DIR) -> int:
    backend = backend or KeychainCredentialBackend()
    try:
        if not (Path(config_dir) / "subscriptions.json").exists():
            configured = backend.is_configured(None)
            print(f"Configured: {'yes' if configured else 'no'}")
            return 0
        registry = SubscriptionRegistry(config_dir)
        records = [registry.resolve(selector)] if selector else registry.records
        if not selector:
            active = sum(record["status"] == "active" for record in records)
            print(f"Subscriptions: {len(records)} ({active} active)")
        for record in records:
            state = _read_record_state(config_dir, record["id"])
            configured = (record["status"] == "active"
                          and backend.is_configured(record["id"]))
            print(f"{record['name']} ({record['id'][:8]}): {record['status']}, "
                  f"credential={'yes' if configured else 'no'}, nodes={state.get('node_count', 0)}")
            if state.get("last_success"):
                print(f"  Last success: {state['last_success']}")
            if state.get("last_error"):
                print(f"  Last error: {state['last_error']}")
        return 0
    except SubscriptionError as exc:
        print(f"Subscription status failed [{exc.category}]: {exc}")
        return 1


def cmd_subscription_remove(selector: Optional[str] = None,
                            backend: Optional[CredentialBackend] = None,
                            config_dir: Path = CONFIG_DIR) -> int:
    backend = backend or KeychainCredentialBackend()
    try:
        with CompositeWriterLock(config_dir):
            registry = _ensure_registry_migrated(backend, config_dir)
            record = registry.mark_removed(selector or "")
            registry.save()
            try:
                backend.delete_url(record["id"])
            except SubscriptionError:
                registry.restore_active(record["id"])
                registry.save()
                raise
        print(f"✓ Subscription removed: {record['name']}; cached nodes retained [removed]")
        print("Removal cannot be undone; run fleet refresh to purge, then add the subscription again.")
        return 0
    except (OSError, SubscriptionError) as exc:
        category = exc.category if isinstance(exc, SubscriptionError) else "registry"
        print(f"Subscription remove failed [{category}]: {exc}")
        return 1


def _recover_subscription_url(config: Dict[str, Any]) -> Optional[str]:
    for key in ("subscription-url", "subscription_url", "url"):
        value = config.get(key)
        if isinstance(value, str):
            try:
                return validate_subscription_url(value)
            except SubscriptionError:
                pass
    return None


def _migrate_subscription(source_path: Path, url: Optional[str],
                          backend: CredentialBackend, config_dir: Path,
                          name: Optional[str] = None) -> int:
    try:
        source = source_path.read_bytes()
        with tempfile.TemporaryDirectory(prefix="fleet-migrate-") as tmp:
            path = Path(tmp) / "source.yaml"
            path.write_bytes(source)
            parsed = _parse_subscription_yaml_strict(path)
        target_url = validate_subscription_url(url) if url else _recover_subscription_url(parsed)
        if not target_url:
            raise SubscriptionError("credential", "Subscription URL could not be recovered; use --url")
        nodes, counts = validate_nodes(parsed["proxies"])
        if (len(nodes) != MIGRATION_BASELINE_TOTAL
                or counts != MIGRATION_BASELINE_COUNTS):
            raise SubscriptionError("migration", "Source does not match the 44-node migration baseline")
        validate_with_sing_box(nodes)
        registry = _ensure_registry_migrated(
            backend, config_dir, allow_uncredentialed_legacy=True)
        record = registry.add(name)
        backend.set_url(record["id"], target_url)
        try:
            generation = GenerationStore(_subscription_root(config_dir, record["id"])).publish(
                source, nodes, counts)
            now = datetime.now(timezone.utc).isoformat()
            _write_record_state(config_dir, record["id"], {
                "schema": 1, "last_attempt": now, "last_success": now,
                "generation": generation, "node_count": MIGRATION_BASELINE_TOTAL,
                "protocol_counts": counts,
            })
            registry.save()
        except Exception:
            try:
                backend.delete_url(record["id"])
            except Exception:
                pass
            shutil.rmtree(_subscription_root(config_dir, record["id"]), ignore_errors=True)
            raise
        print(f"✓ Migrated {record['name']} ({record['id'][:8]}): "
              f"{MIGRATION_BASELINE_TOTAL} nodes "
              "(vmess: 29, hysteria2: 4, anytls: 11, trojan: 0)")
        return 0
    except (OSError, SubscriptionError) as exc:
        category = exc.category if isinstance(exc, SubscriptionError) else "migration"
        message = str(exc) if isinstance(exc, SubscriptionError) else "source could not be imported"
        print(f"Migration failed [{category}]: {message}")
        return 1


def cmd_subscription_migrate(source_path: Path = CLASH_CONFIG, url: Optional[str] = None,
                             backend: Optional[CredentialBackend] = None,
                             config_dir: Path = CONFIG_DIR,
                             name: Optional[str] = None) -> int:
    backend = backend or KeychainCredentialBackend()
    try:
        with CompositeWriterLock(config_dir):
            return _migrate_subscription(source_path, url, backend, config_dir, name)
    except SubscriptionError as exc:
        print(f"Migration failed [{exc.category}]: source could not be imported")
        return 1


def cmd_ping(nodes: List[Dict], target: Optional[str] = None):
    """Test TCP latency to node servers."""
    import concurrent.futures
    import socket as sock_mod

    targets = nodes
    if target:
        n = _find_node(nodes, target)
        if not n:
            return 1
        targets = [n]

    def _tcp_latency(node: Dict) -> tuple:
        key = node.get("_fleet", {}).get("node_key", node["name"])
        server = node.get("server", "")
        port = node.get("port", 443)
        try:
            t0 = time.monotonic()
            with sock_mod.create_connection((server, port), timeout=5):
                elapsed = (time.monotonic() - t0) * 1000
            return (key, elapsed)
        except Exception:
            return (key, None)

    print(f"Testing TCP latency to {len(targets)} node(s)...")
    print(f"{'':4s} {'NODE':38s} {'LATENCY':>10s}")
    print("-" * 56)

    with concurrent.futures.ThreadPoolExecutor(max_workers=20) as executor:
        futures = {executor.submit(_tcp_latency, n): n for n in targets}
        results = []
        for future in concurrent.futures.as_completed(futures):
            name, ms = future.result()
            results.append((name, ms))

    # Preserve original order
    order = {n.get("_fleet", {}).get("node_key", n["name"]): i
             for i, n in enumerate(nodes)}
    results.sort(key=lambda r: order.get(r[0], 999))

    state = _load_state()
    current = state.get("node_key", state.get("node")) if state else None
    labels = {n.get("_fleet", {}).get("node_key", n["name"]): n["name"]
              for n in nodes}

    for key, ms in results:
        name = labels.get(key, key)
        marker = "→" if key == current else " "
        if ms is not None:
            bar = _latency_bar(ms)
            print(f"{marker}  {name:38s} {ms:7.0f}ms {bar}")
        else:
            print(f"{marker}  {name:38s} {'TIMEOUT':>10s}")
    print("-" * 56)
    return 0


def cmd_export(nodes: List[Dict], target: str, mode: str = "proxy"):
    node = _find_node(nodes, target)
    if not node:
        return 1
    config = mk_tun_config(node) if mode == "tun" else mk_proxy_config(node)
    print(json.dumps(config, indent=2, ensure_ascii=False))
    return 0


def _latency_bar(ms: float) -> str:
    """Visual latency indicator."""
    if ms < 100:
        return "🟢"
    elif ms < 300:
        return "🟡"
    elif ms < 800:
        return "🟠"
    else:
        return "🔴"


def _test_proxy():
    """Quick connectivity test through the proxy."""
    try:
        t0 = time.monotonic()
        result = subprocess.run(
            ["curl", "-x", f"http://{PROXY_HOST}:{PROXY_PORT}",
             "-s", "-o", "/dev/null", "-w", "%{http_code}",
             "--connect-timeout", "8", "https://api.github.com"],
            capture_output=True, text=True, timeout=12
        )
        elapsed = (time.monotonic() - t0) * 1000
        code = result.stdout.strip()
        if code and code != "000":
            print(f"  Test:    api.github.com → HTTP {code} ({elapsed:.0f}ms) ✓")
        else:
            print(f"  Test:    api.github.com → TIMEOUT ✗")
    except Exception:
        print(f"  Test:    failed")


# ═══════════════════════════════════════════════════════════════════════════════
# Helpers
# ═══════════════════════════════════════════════════════════════════════════════

def _find_node(nodes: List[Dict], target: str) -> Optional[Dict]:
    if not target:
        print("Node required. Use 'fleet list' to choose a name or index.")
        return None
    try:
        idx = int(target)
        if 0 <= idx < len(nodes):
            return nodes[idx]
    except ValueError:
        pass
    if target.startswith("@") and "/" in target:
        subscription_name, node_name = target[1:].split("/", 1)
        qualified = [n for n in nodes
                     if n.get("_fleet", {}).get("subscription_name", "").casefold()
                     == subscription_name.casefold() and n["name"] == node_name]
        if len(qualified) == 1:
            return qualified[0]
        print(f"Node not found: {target}")
        return None
    exact = [n for n in nodes if n["name"] == target]
    if len(exact) == 1:
        return exact[0]
    if len(exact) > 1:
        print(f"Node name is ambiguous: {target}")
        for node in exact:
            source = node.get("_fleet", {}).get("subscription_name", "legacy")
            print(f"  @{source}/{node['name']}")
        return None
    matches = [n for n in nodes if target.lower() in n["name"].lower()]
    if len(matches) == 1:
        return matches[0]
    elif len(matches) > 1:
        print(f"Multiple matches for '{target}':")
        for m in matches:
            source = m.get("_fleet", {}).get("subscription_name")
            print(f"  @{source}/{m['name']}" if source else f"  {m['name']}")
        return None
    print(f"Node not found: {target}")
    return None


def _load_nodes() -> List[Dict]:
    if SUBSCRIPTIONS_FILE.exists():
        return load_aggregated_nodes(config_dir=CONFIG_DIR, warn=True)
    return GenerationStore(CONFIG_DIR).load_nodes(warn=True)


# ═══════════════════════════════════════════════════════════════════════════════
# Main
# ═══════════════════════════════════════════════════════════════════════════════

HELP = f"""fleet — CLI proxy node manager backed by sing-box.

Two modes:
  proxy   HTTP/SOCKS on {PROXY_HOST}:{PROXY_PORT}   (also sets macOS system proxy)
  tun     System-wide TUN + fake-IP DNS  (needs sudo, Docker auto-proxied)

Commands:
  subscription add [NAME] [URL]  Add a named or auto-named subscription
  subscription status [NAME|ID]  Show redacted subscription status
  subscription remove NAME|ID    Remove credential, retain cache until refresh
  subscription migrate            Import FlClash snapshot (use --name/--url)
  refresh [NAME|ID] [--force]     Refresh one or all active subscriptions
  list                            List aggregated nodes and their sources
  ping [name|index|@source/node]  Test TCP latency

  proxy start <name|index>  Start proxy mode
  proxy stop                Stop proxy mode
  proxy switch <name|index> Switch node (proxy mode)
  proxy status              Shortcut: status

  tun start <name|index>    Start TUN mode (needs sudo)
  tun stop                  Stop TUN mode
  tun switch <name|index>   Switch node (TUN mode)
  tun status                Shortcut: status

  start <name|index>        Start (default: proxy mode)
  stop                      Stop whatever is running
  status                    Show current state
  switch <name|index>       Switch in active mode

  export <name|index>       Export sing-box config (proxy mode)
  export tun <name|index>   Export sing-box config (TUN mode)

Config dir: ~/.config/fleet/
Backend:    sing-box (brew install sing-box)"""


def main():
    args = sys.argv[1:]
    if not args or args[0] in ("help", "-h", "--help"):
        print(HELP)
        return 0

    cmd = args[0]

    if cmd == "subscription":
        sub = args[1] if len(args) > 1 else ""
        rest = args[2:]
        if sub == "add":
            if len(rest) > 2:
                print("Try: fleet subscription add [NAME] [URL]")
                return 1
            if len(rest) == 2:
                return cmd_subscription_add(rest[0], rest[1])
            if len(rest) == 1 and rest[0].lower().startswith("https://"):
                return cmd_subscription_add(None, rest[0])
            return cmd_subscription_add(rest[0] if rest else None, None)
        if sub == "status":
            if len(rest) > 1:
                print("Try: fleet subscription status [NAME|ID]")
                return 1
            return cmd_subscription_status(rest[0] if rest else None)
        if sub == "remove":
            if len(rest) != 1:
                print("Try: fleet subscription remove NAME|ID")
                return 1
            return cmd_subscription_remove(rest[0])
        if sub == "migrate":
            url = None
            name = None
            source = CLASH_CONFIG
            index = 0
            while index < len(rest):
                if rest[index] == "--url" and index + 1 < len(rest):
                    url = rest[index + 1]
                    index += 2
                elif rest[index] == "--source" and index + 1 < len(rest):
                    source = Path(rest[index + 1])
                    index += 2
                elif rest[index] == "--name" and index + 1 < len(rest):
                    name = rest[index + 1]
                    index += 2
                else:
                    print("Try: fleet subscription migrate [--name NAME] [--url URL] [--source PATH]")
                    return 1
            return cmd_subscription_migrate(source, url, name=name)
        print("Try: fleet subscription add|status|remove|migrate")
        return 1

    # ── Subcommand: proxy ──
    if cmd == "proxy":
        sub = args[1] if len(args) > 1 else ""
        target = args[2] if len(args) > 2 else ""
        if sub == "start":
            return cmd_start(_load_nodes(), target, "proxy")
        elif sub == "stop":
            return cmd_stop()
        elif sub in ("switch", "sw"):
            return cmd_switch(_load_nodes(), target, "proxy")
        elif sub in ("status", "st"):
            return cmd_status()
        else:
            print(f"Unknown proxy subcommand: {sub}")
            print("Try: fleet proxy start|stop|switch|status")
            return 1
    # ── Subcommand: tun ──
    elif cmd == "tun":
        sub = args[1] if len(args) > 1 else ""
        target = args[2] if len(args) > 2 else ""
        if sub == "start":
            return cmd_start(_load_nodes(), target, "tun")
        elif sub == "stop":
            return cmd_stop()
        elif sub in ("switch", "sw"):
            return cmd_switch(_load_nodes(), target, "tun")
        elif sub in ("status", "st"):
            return cmd_status()
        else:
            print(f"Unknown tun subcommand: {sub}")
            print("Try: fleet tun start|stop|switch|status")
            return 1
    # ── Top-level commands ──
    elif cmd == "refresh":
        rest = args[1:]
        selectors = [arg for arg in rest if arg != "--force"]
        if len(selectors) > 1:
            print("Try: fleet refresh [NAME|ID] [--force]")
            return 1
        return cmd_refresh(force="--force" in rest,
                           selector=selectors[0] if selectors else None)
    elif cmd in ("list", "ls"):
        return cmd_list(_load_nodes())
    elif cmd == "start":
        return cmd_start(_load_nodes(), args[1] if len(args) > 1 else "", "proxy")
    elif cmd == "stop":
        return cmd_stop()
    elif cmd in ("status", "st"):
        return cmd_status()
    elif cmd in ("switch", "sw"):
        return cmd_switch(_load_nodes(), args[1] if len(args) > 1 else "")
    elif cmd in ("ping", "bench"):
        target = args[1] if len(args) > 1 else None
        return cmd_ping(_load_nodes(), target)
    elif cmd == "export":
        sub = args[1] if len(args) > 1 else ""
        if sub == "tun":
            return cmd_export(_load_nodes(), args[2] if len(args) > 2 else "", "tun")
        else:
            return cmd_export(_load_nodes(), sub, "proxy")
    else:
        print(f"Unknown command: {cmd}")
        print("Try: fleet help")
        return 1


if __name__ == "__main__":
    sys.exit(main() or 0)
