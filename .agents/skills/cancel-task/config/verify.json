{
  "skill": "cancel-task",
  "checks": {
    "task-meta": {
      "required_fields": [
        "id",
        "type",
        "workflow",
        "status",
        "created_at",
        "updated_at",
        "agent_infra_version",
        "current_step",
        "assigned_to",
        "cancelled_at",
        "cancel_reason"
      ],
      "expected_status": "completed",
      "require_cancelled_at": true
    },
    "activity-log": {
      "expected_action_pattern": "(Cancel Task|Cancelled)",
      "freshness_minutes": 30
    },
    "platform-sync": {
      "when": "issue_number_exists",
      "expected_comment_marker": "<!-- sync-issue:{task-id}:cancel -->",
      "verify_task_comment_content": true,
      "expected_comment_marker_key": "cancel"
    }
  }
}
