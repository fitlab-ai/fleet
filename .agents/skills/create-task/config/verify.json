{
  "skill": "create-task",
  "checks": {
    "task-meta": {
      "required_fields": [
        "id",
        "type",
        "branch",
        "workflow",
        "status",
        "created_at",
        "updated_at",
        "agent_infra_version",
        "current_step",
        "assigned_to"
      ],
      "expected_step": "requirement-analysis",
      "expected_status": "active"
    },
    "activity-log": {
      "expected_action_pattern": "(Create Task|Task Created)",
      "freshness_minutes": 30
    },
    "platform-sync": {
      "when": "issue_number_exists",
      "issue_must_exist": true,
      "verify_task_comment_content": true,
      "verify_milestone": true,
      "expected_status_label_key": "waitingForTriage"
    }
  }
}
